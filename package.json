{
  "name": "lastgate",
  "private": true,
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/AaronCx/LastGate.git"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "bun run --filter './apps/*' dev",
    "build": "bun run --filter '*' build",
    "lint": "bun run --filter '*' lint",
    "test": "bun run --filter '*' test",
    "type-check": "bun run --filter '*' type-check"
  },
  "devDependencies": {
    "@biomejs/biome": "1.9.4"
  }
}
